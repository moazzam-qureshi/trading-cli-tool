BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true

# Discord webhooks (one channel per purpose — leave blank to fall back to SIGNALS)
DISCORD_WEBHOOK_SIGNALS=        # active trade events: opened/closed/near-stop/heartbeat
DISCORD_WEBHOOK_SCANNER=        # A+ setup scan results from setup-scan
DISCORD_WEBHOOK_REPORTS=        # daily P&L summaries
DISCORD_WEBHOOK_JOURNAL=        # auto-posted trade post-mortems on close
DISCORD_WEBHOOK_SYSTEM=         # daemon errors, restarts, health

# Daemon settings (tune for VPS)
DAEMON_POSITION_INTERVAL=60        # seconds between position checks
DAEMON_SCANNER_INTERVAL=1800       # seconds between A+ setup scans (30min)
DAEMON_HEARTBEAT_MINUTES=30        # heartbeat per open position
DAEMON_NEAR_PCT=0.4                # alert when within N% of stop/target
DAEMON_SCAN_TOP=30                 # how many top-volume coins to scan
DAEMON_SCAN_MIN_SCORE=8            # minimum confluence score to alert
DAEMON_DAILY_REPORT_HOUR_UTC=0     # hour to post daily report (0 = midnight UTC)
